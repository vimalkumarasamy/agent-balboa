# --- LLM ---
# "lemonade" uses local Qwen3-8B via Lemonade (free, offline)
# "claude" uses Anthropic API (requires ANTHROPIC_API_KEY)
LLM_PROVIDER=lemonade
ANTHROPIC_API_KEY=

# --- Strava ---
# Get these from strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=   # auto-filled after running: python scripts/strava_auth.py

# --- Location ---
# Used for weather forecasts
HOME_CITY=Seattle, WA

# --- Coach plan (optional) ---
# Google Sheets URL shared as "Anyone with the link can view"
COACH_SHEET_URL=
